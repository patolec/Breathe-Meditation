    <script>
        // ==================== 数据存储 ====================
        const STORAGE_KEY = 'meditation_data';

        function getData() {
            const data = localStorage.getItem(STORAGE_KEY);
            return data ? JSON.parse(data) : {
                sessions: 0,
                totalMinutes: 0,
                totalCycles: 0,
                streak: 0,
                lastDate: null,
                habits: {},
                habitStreak: 0,
                lastHabitDate: null
            };
        }

        function saveData(data) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        }

        // ==================== 音频系统 ====================
        let audioCtx = null;

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            return audioCtx;
        }

        function playTone(frequency, duration, type = 'sine') {
            const ctx = initAudio();
            const oscillator = ctx.createOscillator();
            const gainNode = ctx.createGain();

            oscillator.connect(gainNode);
            gainNode.connect(ctx.destination);

            oscillator.type = type;
            oscillator.frequency.setValueAtTime(frequency, ctx.currentTime);

            gainNode.gain.setValueAtTime(0, ctx.currentTime);
            gainNode.gain.linearRampToValueAtTime(0.3, ctx.currentTime + 0.05);
            gainNode.gain.linearRampToValueAtTime(0, ctx.currentTime + duration);

            oscillator.start(ctx.currentTime);
            oscillator.stop(ctx.currentTime + duration);
        }

        function playInhaleSound() { playTone(523.25, 0.3, 'sine'); }
        function playHoldSound() { playTone(392, 0.2, 'triangle'); }
        function playExhaleSound() { playTone(329.63, 0.4, 'sine'); }

        // ==================== 冥想控制 ====================
        const sessions = {
            stress: { inhale: 4, hold: 7, exhale: 8, name: '4-7-8 呼吸法' },
            sleep: { inhale: 4, hold: 6, exhale: 6, name: '4-6 助眠呼吸' },
            energy: { inhale: 1, hold: 0, exhale: 1, name: '快速唤醒呼吸' },
            focus: { inhale: 4, hold: 4, exhale: 4, name: '等比呼吸法' }
        };

        let currentSession = 'stress';
        let breathTimes = { ...sessions.stress };
        let selectedDuration = 300;
        let isPlaying = false;
        let timer = null;
        let breathTimer = null;
        let remainingTime = 300;
        let cycleCount = 0;

        // DOM 元素
        const playBtn = document.getElementById('playBtn');
        const resetBtn = document.getElementById('resetBtn');
        const fullscreenBtn = document.getElementById('fullscreenBtn');
        const breathCircle = document.getElementById('breathCircle');
        const breathPhase = document.getElementById('breathPhase');
        const breathCount = document.getElementById('breathCount');
        const breathModeInfo = document.getElementById('breathModeInfo');
        const timerDisplay = document.getElementById('timerDisplay');
        const guideBtn = document.getElementById('guideBtn');
        const vibrateBtn = document.getElementById('vibrateBtn');
        const historyBtn = document.getElementById('historyBtn');
        const completeModal = document.getElementById('completeModal');
        const historyModal = document.getElementById('historyModal');
        const doneBtn = document.getElementById('doneBtn');
        const closeHistoryBtn = document.getElementById('closeHistoryBtn');
        const inhaleSlider = document.getElementById('inhaleSlider');
        const holdSlider = document.getElementById('holdSlider');
        const exhaleSlider = document.getElementById('exhaleSlider');

        // 初始化
        function init() {
            updateStats();
            updateTodayDate();

            // 会话选择
            document.querySelectorAll('.session-card').forEach(card => {
                card.addEventListener('click', () => {
                    if (isPlaying) return;

                    document.querySelectorAll('.session-card').forEach(c => c.classList.remove('active'));
                    card.classList.add('active');

                    currentSession = card.dataset.session;
                    breathTimes = { ...sessions[currentSession] };

                    inhaleSlider.value = breathTimes.inhale;
                    holdSlider.value = breathTimes.hold;
                    exhaleSlider.value = breathTimes.exhale;

                    updateSliderValues();
                    updateModeInfo();
                });
            });

            // 时长选择
            document.querySelectorAll('.dur-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    if (isPlaying) return;

                    document.querySelectorAll('.dur-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    selectedDuration = parseInt(btn.dataset.duration);
                    remainingTime = selectedDuration;
                    updateTimerDisplay();
                });
            });

            // 播放/暂停
            playBtn.addEventListener('click', togglePlay);

            // 重置
            resetBtn.addEventListener('click', resetMeditation);

            // 全屏
            fullscreenBtn.addEventListener('click', toggleFullscreen);

            // 引导音
            guideBtn.addEventListener('click', () => {
                guideBtn.classList.toggle('active');
            });

            // 震动
            vibrateBtn.addEventListener('click', () => {
                vibrateBtn.classList.toggle('active');
            });

            // 历史统计
            historyBtn.addEventListener('click', showHistory);

            // 弹窗关闭
            doneBtn.addEventListener('click', () => {
                completeModal.classList.remove('show');
            });

            closeHistoryBtn.addEventListener('click', () => {
                historyModal.classList.remove('show');
            });

            // 自定义滑块
            [inhaleSlider, holdSlider, exhaleSlider].forEach(slider => {
                slider.addEventListener('input', () => {
                    breathTimes.inhale = parseInt(inhaleSlider.value);
                    breathTimes.hold = parseInt(holdSlider.value);
                    breathTimes.exhale = parseInt(exhaleSlider.value);
                    updateSliderValues();
                    updateModeInfo();

                    document.querySelectorAll('.session-card').forEach(c => c.classList.remove('active'));
                });
            });

            // 打卡功能
            initHabits();

            // 按钮事件
            document.getElementById('start-btn').addEventListener('click', () => {
                document.getElementById('meditation-section').scrollIntoView({ behavior: 'smooth' });
            });

            document.getElementById('remind-btn').addEventListener('click', () => {
                alert('提醒功能需要浏览器通知权限支持，暂未实现。请手动设置手机闹钟提醒！');
            });
        }

        function updateSliderValues() {
            document.getElementById('inhaleVal').textContent = breathTimes.inhale;
            document.getElementById('holdVal').textContent = breathTimes.hold;
            document.getElementById('exhaleVal').textContent = breathTimes.exhale;
        }

        function updateModeInfo() {
            const { inhale, hold, exhale } = breathTimes;
            breathModeInfo.textContent = `${inhale}-${hold}-${exhale} 呼吸法`;
        }

        function updateTimerDisplay() {
            const minutes = Math.floor(remainingTime / 60);
            const seconds = remainingTime % 60;
            timerDisplay.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
        }

        function togglePlay() {
            if (isPlaying) {
                pauseMeditation();
            } else {
                startMeditation();
            }
        }

        function startMeditation() {
            isPlaying = true;
            playBtn.textContent = '⏸';
            initAudio();

            // 开始呼吸循环
            runBreathCycle();

            // 开始倒计时
            timer = setInterval(() => {
                remainingTime--;
                updateTimerDisplay();

                if (remainingTime <= 0) {
                    completeMeditation();
                }
            }, 1000);
        }

        function pauseMeditation() {
            isPlaying = false;
            playBtn.textContent = '▶';
            clearInterval(timer);
            clearTimeout(breathTimer);

            breathCircle.classList.remove('inhale', 'hold', 'exhale');
            breathPhase.textContent = '已暂停';
            breathCount.textContent = '';
        }

        function resetMeditation() {
            pauseMeditation();
            remainingTime = selectedDuration;
            cycleCount = 0;
            updateTimerDisplay();
            breathPhase.textContent = '准备开始';
        }

        function runBreathCycle() {
            if (!isPlaying) return;

            cycleCount++;
            const { inhale, hold, exhale } = breathTimes;

            // 吸气
            breathCircle.classList.remove('hold', 'exhale');
            breathCircle.classList.add('inhale');
            breathPhase.textContent = '吸气';
            breathCount.textContent = inhale;

            if (guideBtn.classList.contains('active')) {
                playInhaleSound();
            }
            if (vibrateBtn.classList.contains('active') && navigator.vibrate) {
                navigator.vibrate(100);
            }

            animateCount(inhale, () => {
                if (!isPlaying) return;

                // 屏息
                breathCircle.classList.remove('inhale');
                breathCircle.classList.add('hold');
                breathPhase.textContent = hold > 0 ? '屏息' : '呼气';
                breathCount.textContent = hold > 0 ? hold : exhale;

                if (hold > 0 && guideBtn.classList.contains('active')) {
                    playHoldSound();
                }

                if (hold > 0) {
                    animateCount(hold, () => {
                        if (!isPlaying) return;
                        doExhale();
                    });
                } else {
                    doExhale();
                }
            });
        }

        function doExhale() {
            const { exhale } = breathTimes;

            breathCircle.classList.remove('hold');
            breathCircle.classList.add('exhale');
            breathPhase.textContent = '呼气';
            breathCount.textContent = exhale;

            if (guideBtn.classList.contains('active')) {
                playExhaleSound();
            }
            if (vibrateBtn.classList.contains('active') && navigator.vibrate) {
                navigator.vibrate([50, 50, 50]);
            }

            animateCount(exhale, () => {
                if (!isPlaying) return;
                runBreathCycle();
            });
        }

        function animateCount(seconds, callback) {
            let count = seconds;

            const countInterval = setInterval(() => {
                count--;
                if (count > 0) {
                    breathCount.textContent = count;
                } else {
                    clearInterval(countInterval);
                    if (callback) callback();
                }
            }, 1000);
        }

        function completeMeditation() {
            pauseMeditation();

            const data = getData();
            const today = new Date().toDateString();

            data.sessions++;
            data.totalMinutes += Math.round(selectedDuration / 60);
            data.totalCycles += cycleCount;

            if (data.lastDate !== today) {
                const yesterday = new Date();
                yesterday.setDate(yesterday.getDate() - 1);

                if (data.lastDate === yesterday.toDateString()) {
                    data.streak++;
                } else {
                    data.streak = 1;
                }
                data.lastDate = today;
            }

            saveData(data);
            updateStats();

            // 显示完成弹窗
            const quotes = [
                '每一次呼吸，都是与当下的相遇。',
                '平静的内心，是最强大的力量。',
                '专注于呼吸，让思绪如云般飘过。',
                '你正在为大脑注入新的活力。',
                '这一刻，你与自己和谐共处。'
            ];

            document.getElementById('quoteText').textContent = quotes[Math.floor(Math.random() * quotes.length)];
            document.getElementById('statsText').textContent =
                `本次冥想 ${Math.round(selectedDuration / 60)} 分钟，完成 ${cycleCount} 个呼吸循环`;

            completeModal.classList.add('show');
        }

        function updateStats() {
            const data = getData();
            document.getElementById('streakDays').textContent = data.streak;
            document.getElementById('totalMinutes').textContent = data.totalMinutes;
            document.getElementById('statSessions').textContent = data.sessions;
            document.getElementById('statMinutes').textContent = data.totalMinutes;
            document.getElementById('statCycles').textContent = data.totalCycles;
            document.getElementById('statStreak').textContent = data.streak;
        }

        function showHistory() {
            updateStats();
            historyModal.classList.add('show');
        }

        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
            } else {
                document.exitFullscreen();
            }
        }

        // ==================== 打卡功能 ====================
        function initHabits() {
            const data = getData();
            const today = new Date().toDateString();

            // 检查是否是新的一天，重置计数
            if (data.lastHabitDate !== today) {
                data.habits = {};
                data.lastHabitDate = today;
                saveData(data);
            }

            // 加载今日数据
            loadHabits();

            // 绑定按钮事件
            document.querySelectorAll('.habit-card').forEach(card => {
                const habit = card.dataset.habit;
                const minusBtn = card.querySelector('.minus');
                const plusBtn = card.querySelector('.plus');

                minusBtn.addEventListener('click', () => updateHabit(habit, -1));
                plusBtn.addEventListener('click', () => updateHabit(habit, 1));
            });
        }

        function loadHabits() {
            const data = getData();
            const habits = data.habits || {};

            ['water', 'exercise', 'meditation', 'reading', 'social', 'sleep'].forEach(habit => {
                const countEl = document.getElementById(`count-${habit}`);
                if (countEl) {
                    countEl.textContent = habits[habit] || 0;
                }
            });

            updateDailySummary();
        }

        function updateHabit(habit, delta) {
            const data = getData();
            if (!data.habits) data.habits = {};

            const current = data.habits[habit] || 0;
            const newValue = Math.max(0, current + delta);
            data.habits[habit] = newValue;

            saveData(data);

            const countEl = document.getElementById(`count-${habit}`);
            if (countEl) {
                countEl.textContent = newValue;
            }

            updateDailySummary();
        }

        function updateDailySummary() {
            const data = getData();
            const habits = data.habits || {};

            let total = 0;
            Object.values(habits).forEach(v => total += v);

            document.getElementById('totalCheckins').textContent = total;
            document.getElementById('dailyStreak').textContent = data.habitStreak || 0;
        }

        function updateTodayDate() {
            const now = new Date();
            const options = { month: 'long', day: 'numeric', weekday: 'long' };
            document.getElementById('todayDate').textContent = now.toLocaleDateString('zh-CN', options);
        }

        // 启动
        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>
