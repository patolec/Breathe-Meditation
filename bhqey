<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>保护前额叶 - 大脑健康指南</title>
    <style>
        /* ==================== 基础重置与变量 ==================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #8B5CF6;
            --primary-dark: #6D28D9;
            --primary-light: #A78BFA;
            --secondary: #06B6D4;
            --accent: #F59E0B;
            --success: #10B981;
            --warning: #F59E0B;
            --danger: #EF4444;
            --bg-dark: #0F0F1A;
            --bg-card: #1A1A2E;
            --bg-card-hover: #252542;
            --text-primary: #FFFFFF;
            --text-secondary: #A0A0B0;
            --text-muted: #6B6B7B;
            --border: #2A2A3E;
            --shadow: rgba(0, 0, 0, 0.3);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            line-height: 1.6;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* ==================== 头部英雄区 ==================== */
        header.hero {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 60px 5%;
            background: linear-gradient(135deg, #1A1A2E 0%, #16162A 50%, #0F0F1A 100%);
            position: relative;
            overflow: hidden;
        }

        header.hero::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 50%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 70% 80%, rgba(6, 182, 212, 0.08) 0%, transparent 40%);
            animation: pulse 15s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }

        .hero-content {
            flex: 1;
            max-width: 600px;
            position: relative;
            z-index: 1;
        }

        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 16px;
            background: linear-gradient(135deg, var(--primary-light), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: 1.5rem;
            color: var(--text-secondary);
            margin-bottom: 24px;
        }

        .hero-description {
            font-size: 1.1rem;
            color: var(--text-secondary);
            line-height: 1.8;
        }

        .brain-icon {
            flex: 0 0 300px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .brain-icon svg {
            width: 250px;
            height: 250px;
            filter: drop-shadow(0 0 30px rgba(139, 92, 246, 0.5));
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        /* ==================== 提示卡片区域 ==================== */
        .tips-section {
            padding: 80px 0;
            background: var(--bg-dark);
        }

        .tips-section h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 50px;
            color: var(--text-primary);
        }

        .tips-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
        }

        .tip-item {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 32px;
            border: 1px solid var(--border);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .tip-item:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
            box-shadow: 0 20px 40px rgba(139, 92, 246, 0.15);
        }

        .tip-number {
            position: absolute;
            top: 16px;
            right: 20px;
            font-size: 3rem;
            font-weight: 800;
            color: var(--primary);
            opacity: 0.2;
        }

        .tip-item h3 {
            font-size: 1.4rem;
            margin-bottom: 12px;
            color: var(--primary-light);
        }

        .tip-item p {
            color: var(--text-secondary);
            line-height: 1.7;
        }

        /* ==================== 冥想区域 ==================== */
        .meditation-section {
            padding: 60px 20px;
            background: linear-gradient(180deg, var(--bg-dark) 0%, #0D0D1A 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .meditation-container {
            max-width: 500px;
            width: 100%;
            text-align: center;
        }

        .meditation-header {
            margin-bottom: 30px;
        }

        .meditation-header h2 {
            font-size: 2rem;
            margin-bottom: 10px;
            color: var(--text-primary);
        }

        .meditation-intro {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        /* 统计数据 */
        .meditation-stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 25px;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .stat-num {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary-light);
        }

        /* 会话选择器 */
        .session-selector {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .session-card {
            background: var(--bg-card);
            border: 2px solid var(--border);
            border-radius: 12px;
            padding: 12px 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .session-card:hover {
            border-color: var(--primary);
        }

        .session-card.active {
            border-color: var(--primary);
            background: rgba(139, 92, 246, 0.1);
        }

        .session-icon {
            font-size: 1.5rem;
            margin-bottom: 6px;
        }

        .session-name {
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .session-desc {
            font-size: 0.65rem;
            color: var(--text-muted);
        }

        /* 自定义面板 */
        .custom-breath-panel {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }

        .custom-title {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 15px;
        }

        .custom-sliders {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .slider-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .slider-label {
            width: 40px;
            text-align: left;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .slider-input {
            flex: 1;
            height: 6px;
            -webkit-appearance: none;
            appearance: none;
            background: var(--border);
            border-radius: 3px;
            outline: none;
        }

        .slider-input::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            background: var(--primary);
            border-radius: 50%;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .slider-input::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }

        .slider-value {
            width: 30px;
            text-align: center;
            font-weight: 600;
            color: var(--primary-light);
        }

        /* 呼吸圆圈 */
        .breath-area {
            position: relative;
            height: 280px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }

        .breath-circle-outer {
            position: relative;
            width: 200px;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .glow-ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 2px solid var(--primary);
            opacity: 0;
            animation: glow-pulse 4s ease-out infinite;
        }

        .glow-ring:nth-child(1) { animation-delay: 0s; }
        .glow-ring:nth-child(2) { animation-delay: 0.5s; }
        .glow-ring:nth-child(3) { animation-delay: 1s; }

        @keyframes glow-pulse {
            0% { transform: scale(1); opacity: 0.6; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        .breath-circle {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 60px rgba(139, 92, 246, 0.5);
            transition: transform 0.3s ease;
            z-index: 1;
        }

        .breath-circle.inhale {
            animation: breathe-in 4s ease-in-out forwards;
        }

        .breath-circle.hold {
            animation: breathe-hold 7s ease-in-out forwards;
        }

        .breath-circle.exhale {
            animation: breathe-out 8s ease-in-out forwards;
        }

        @keyframes breathe-in {
            0% { transform: scale(1); }
            100% { transform: scale(1.3); }
        }

        @keyframes breathe-hold {
            0%, 100% { transform: scale(1.3); }
        }

        @keyframes breathe-out {
            0% { transform: scale(1.3); }
            100% { transform: scale(1); }
        }

        .breath-content {
            text-align: center;
            color: white;
        }

        .breath-phase {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .breath-count {
            font-size: 2.5rem;
            font-weight: 700;
        }

        .breath-mode-info {
            position: absolute;
            bottom: 10px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        /* 时长选择 */
        .duration-row {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .dur-btn {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

        .dur-btn:hover, .dur-btn.active {
            border-color: var(--primary);
            color: var(--primary-light);
        }

        .dur-btn.active {
            background: rgba(139, 92, 246, 0.15);
        }

        /* 计时器 */
        .timer-area {
            margin-bottom: 25px;
        }

        .timer-time {
            font-size: 3rem;
            font-weight: 300;
            color: var(--text-primary);
            letter-spacing: 2px;
        }

        /* 控制按钮 */
        .breath-controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
        }

        .ctrl-btn {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ctrl-btn.secondary {
            background: var(--bg-card);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

        .ctrl-btn.secondary:hover {
            border-color: var(--primary);
            color: var(--primary-light);
        }

        .ctrl-btn.play {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.4);
        }

        .ctrl-btn.play:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5);
        }

        /* 工具按钮 */
        .breath-tools {
            display: flex;
            justify-content: center;
            gap: 15px;
        }

        .tool-btn {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            padding: 10px 16px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
        }

        .tool-btn:hover, .tool-btn.active {
            border-color: var(--primary);
            color: var(--primary-light);
        }

        .tool-btn.active {
            background: rgba(139, 92, 246, 0.15);
        }

        /* ==================== 行动区域 ==================== */
        .action-section {
            padding: 80px 0;
            text-align: center;
            background: var(--bg-dark);
        }

        .action-section h2 {
            font-size: 2.5rem;
            margin-bottom: 24px;
        }

        .action-text {
            max-width: 700px;
            margin: 0 auto 40px;
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.8;
        }

        .action-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn {
            padding: 16px 32px;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.4);
        }

        .btn-secondary {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            border-color: var(--primary);
        }

        /* ==================== 每日打卡区域 ==================== */
        .daily-habits {
            padding: 80px 0;
            background: linear-gradient(180deg, var(--bg-dark) 0%, #0D0D1A 100%);
        }

        .daily-habits h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 16px;
        }

        .habits-subtitle {
            text-align: center;
            color: var(--text-secondary);
            margin-bottom: 50px;
        }

        .habits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .habit-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            border: 1px solid var(--border);
            transition: all 0.3s ease;
        }

        .habit-card:hover {
            border-color: var(--primary);
            transform: translateY(-3px);
        }

        .habit-icon {
            font-size: 2.5rem;
            margin-bottom: 12px;
        }

        .habit-card h3 {
            font-size: 1.2rem;
            margin-bottom: 8px;
        }

        .habit-desc {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        .habit-counter {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-bottom: 12px;
        }

        .counter-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--bg-card-hover);
            color: var(--text-primary);
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .counter-btn:hover {
            border-color: var(--primary);
            color: var(--primary-light);
        }

        .counter-btn.plus:hover {
            background: var(--primary);
            color: white;
        }

        .counter-value {
            font-size: 1.8rem;
            font-weight: 700;
            min-width: 40px;
        }

        .habit-goal {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        /* 今日统计 */
        .daily-summary {
            display: flex;
            justify-content: center;
        }

        .summary-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px 40px;
            border: 1px solid var(--border);
        }

        .summary-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            gap: 20px;
        }

        .summary-date {
            font-weight: 600;
            color: var(--primary-light);
        }

        .summary-label {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .summary-stats {
            display: flex;
            gap: 30px;
        }

        .summary-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .summary-text {
            font-size: 0.95rem;
            color: var(--text-secondary);
        }

        .summary-text strong {
            color: var(--primary-light);
            font-size: 1.1rem;
        }

        /* ==================== 页脚 ==================== */
        footer {
            padding: 40px 0;
            text-align: center;
            background: var(--bg-dark);
            border-top: 1px solid var(--border);
        }

        footer p {
            color: var(--text-secondary);
            margin-bottom: 8px;
        }

        .disclaimer {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        /* ==================== 弹窗样式 ==================== */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal-box {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 40px;
            text-align: center;
            max-width: 400px;
            border: 1px solid var(--border);
            animation: modal-in 0.3s ease;
        }

        @keyframes modal-in {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .modal-icon {
            font-size: 4rem;
            margin-bottom: 20px;
        }

        .modal-title {
            font-size: 1.8rem;
            margin-bottom: 16px;
        }

        .modal-quote {
            font-size: 1rem;
            color: var(--text-secondary);
            margin-bottom: 20px;
            font-style: italic;
        }

        .modal-stats {
            font-size: 0.95rem;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .modal-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            padding: 14px 40px;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .modal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.4);
        }

        /* 历史统计弹窗 */
        .history-box {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 30px;
            max-width: 450px;
            width: 90%;
            border: 1px solid var(--border);
        }

        .history-title {
            text-align: center;
            font-size: 1.5rem;
            margin-bottom: 24px;
        }

        .stat-grid-modal {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card-modal {
            background: var(--bg-card-hover);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }

        .stat-num-modal {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary-light);
            margin-bottom: 6px;
        }

        .stat-label-modal {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .history-close {
            width: 100%;
            background: var(--bg-card-hover);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 12px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .history-close:hover {
            border-color: var(--primary);
        }

        /* ==================== 响应式设计 ==================== */
        @media (max-width: 768px) {
            header.hero {
                flex-direction: column;
                text-align: center;
                padding: 40px 20px;
                min-height: auto;
            }

            .hero-content h1 {
                font-size: 2.5rem;
            }

            .brain-icon {
                margin-top: 40px;
            }

            .brain-icon svg {
                width: 180px;
                height: 180px;
            }

            .session-selector {
                grid-template-columns: repeat(2, 1fr);
            }

            .breath-circle-outer {
                width: 160px;
                height: 160px;
            }

            .breath-circle {
                width: 130px;
                height: 130px;
            }

            .timer-time {
                font-size: 2.5rem;
            }

            .summary-header {
                flex-direction: column;
                gap: 8px;
            }

            .summary-stats {
                flex-direction: column;
                gap: 12px;
            }
        }
    </style>
</head>
<body>
    <header class="hero">
        <div class="hero-content">
            <h1>保护前额叶</h1>
            <p class="subtitle">守护大脑的"指挥官"，提升生活质量</p>
